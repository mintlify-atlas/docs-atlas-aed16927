  "keyFeatures": [
    "Multi-tenant architecture with custom domains and branding",
    "Role-based access control (Admin, Coach, Athlete)",
    "WOD (Workout of the Day) designer and programming",
    "Class scheduling and booking system",
    "Member and lead management",
    "Competition management with live leaderboards",
    "Billing and subscription management",
    "Analytics and performance tracking",
    "Benchmark tracking and progress monitoring",
    "Movement library with video demonstrations",
    "Multi-language support (i18n)",
    "Audit logging and security features",
    "Custom branding (logos, favicons, themes)",
    "Mobile-responsive design"
  ],
  "publicApiSurface": [
    "AuthContext - Authentication state and methods",
    "TenantContext - Multi-tenant box resolution",
    "useLanguage - Internationalization hook",
    "useNotification - Toast notification hook",
    "useMediaQuery - Responsive design hook",
    "supabaseClient - Configured Supabase client",
    "Dashboard - Main dashboard component",
    "Members - Member management interface",
    "Leads - Lead tracking interface",
    "Wods - WOD programming interface",
    "WODDesigner - WOD creation component",
    "Schedule - Class scheduling interface",
    "Competitions - Competition management",
    "Billing - Subscription and payment management",
    "Analytics - Performance analytics dashboard",
    "Benchmarks - Benchmark tracking",
    "Movements - Exercise library",
    "Profile - User profile management",
    "Settings - Box configuration settings",
    "Roles - Role management interface",
    "AuditLogs - Security audit logging"
  ]
